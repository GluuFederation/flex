{
  "name": "gluu-admin-ui",
  "version": "0.0.0",
  "description": "UI to administer the jans-sever features",
  "keywords": [
    "jans-server",
    "janssen",
    "oauth",
    "admin-ui",
    "gluu"
  ],
  "homepage": "/admin",
  "bugs": {
    "url": "https://github.com/GluuFederation/gluu-admin-ui/issues",
    "email": "team@gluu.org"
  },
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "https://opensource.org/licenses/apache2.0.php"
    }
  ],
  "main": "index.js",
  "scripts": {
    "test": "set NODE_ENV=test&& jest --forceExit",
    "clear_jest": "jest --clearCache",
    "test:watch": "npm test -- --watch",
    "start": "npm run start:dev",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "build:adminuitest": "vite build --mode adminuitest",
    "build:goldencrane": "vite build --mode goldencrane",
    "start:dev": "vite --mode development",
    "start:prod": "vite preview --mode production",
    "preview": "vite preview",
    "lint": "eslint app/ plugins/ --ext .js,.jsx,.ts,.tsx --fix",
    "lint:check": "eslint app/ plugins/ --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "check:all": "ts-node --files --project script/tsconfig.json script/check-all.ts",
    "format": "ts-node --files --project script/tsconfig.json script/format.ts",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss}\"",
    "api:orval": "rimraf jans_config_api_orval && openapi-merge-cli && orval --config ./orval.config.ts && ts-node --files --project script/tsconfig.json script/fix-orval-enums.ts",
    "plugin:showAll": "ts-node --files --project script/tsconfig.json ./build/plugin-cli.ts --showAllPlugins",
    "plugin:add": "ts-node --files --project script/tsconfig.json ./build/plugin-cli.ts --addPlugin",
    "plugin:remove": "ts-node --files --project script/tsconfig.json ./build/plugin-cli.ts --removePlugin",
    "plugin:clean": "ts-node --files --project script/tsconfig.json ./build/plugin-cli.ts --cleanExceptDefault admin,auth-server --resetPluginConfig",
    "analyze": "ANALYZE=true npm run build:prod",
    "analyze:dev": "ANALYZE=true npm run build:dev",
    "prepare": "cd .. && npx husky install && git config core.hooksPath admin-ui/.husky"
  },
  "author": "gluu inc.",
  "license": "Apache",
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-modules-commonjs": "^7.21.2",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.21.4",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.7.0",
    "@testing-library/dom": "^9.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/animejs": "^3.1.13",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.17",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/react-toggle": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.3.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.0.0",
    "mkdirp": "^3.0.1",
    "orval": "^7.13.2",
    "prettier": "^3.8.3",
    "redux-saga-test-plan": "^4.0.6",
    "rimraf": "^6.1.3",
    "sass": "^1.70.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-plugin-css-modules": "^5.1.0",
    "vite": "^8.0.10",
    "vite-plugin-wasm": "^3.6.0",
    "yaml-loader": "^0.9.0"
  },
  "dependencies": {
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@janssenproject/cedarling_wasm": "0.0.338",
    "@material-table/core": "6.4.4",
    "@mui/base": "^5.0.0-alpha.124",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.15.14",
    "@mui/x-date-pickers": "^7.0.0",
    "@openid/appauth": "^1.3.1",
    "@reduxjs/toolkit": "^2.2.1",
    "@tanstack/react-query": "^5.100.7",
    "@tanstack/react-query-devtools": "^5.100.7",
    "ace-builds": "^1.43.6",
    "animejs": "^3.2.2",
    "axios": "^1.15.2",
    "bootstrap": "^5.3.0",
    "dayjs": "^1.11.7",
    "formik": "^2.2.9",
    "i18next": "^26.0.8",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.18.1",
    "openapi-merge-cli": "^1.3.2",
    "postcss": "^8.4.21",
    "pretty-checkbox": "^3.0.3",
    "prop-types": "^15.8.1",
    "query-string": "^9.0.0",
    "react": "18.3.1",
    "react-ace": "^14.0.1",
    "react-bootstrap-typeahead": "^6.1.1",
    "react-dom": "18.3.1",
    "react-dropzone": "^15.0.0",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.6",
    "react-idle-timer": "^5.5.3",
    "react-json-view-lite": "^2.4.1",
    "react-redux": "^9.1.0",
    "react-responsive": "^10.0.0",
    "react-router": "^6.22.3",
    "react-router-dom": "^6.22.3",
    "react-toastify": "^11.1.0",
    "react-toggle": "^4.1.3",
    "react-tooltip": "^6.0.0",
    "reactstrap": "^9.2.3",
    "recharts": "^3.8.1",
    "redux-persist": "^6.0.0",
    "redux-saga": "^1.2.3",
    "tss-react": "^4.8.2",
    "yup": "^1.4.0"
  },
  "resolutions": {
    "ansi-regex": "^5.0.1",
    "set-value": "^4.1.0",
    "jspdf": "^2.4.0",
    "autoprefixer": "^10.4.14"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:react/recommended",
      "eslint:recommended"
    ],
    "rules": {},
    "parserOptions": {
      "parser": "babel-eslint"
    }
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --cache --max-warnings=0",
      "prettier --check"
    ],
    "*.json": [
      "prettier --check"
    ]
  }
}
