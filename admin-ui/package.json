{
  "name": "gluu-admin-ui",
  "version": "0.0.0",
  "description": "UI to administer the jans-sever features",
  "keywords": [
    "jans-server",
    "janssen",
    "oauth",
    "admin-ui",
    "gluu"
  ],
  "homepage": "/admin",
  "bugs": {
    "url": "https://github.com/GluuFederation/gluu-admin-ui/issues",
    "email": "team@gluu.org"
  },
  "author": "gluu inc.",
  "license": "Apache-2.0",
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "test": "jest",
    "test:all": "jest --runInBand --watchman=false",
    "start": "npm run cache:terminal:clean && npm run start:dev",
    "start:dev": "npm run cache:terminal:clean && vite --mode development",
    "build:dev": "npm run cache:terminal:clean && vite build --mode development",
    "build:prod": "npm run cache:terminal:clean && vite build --mode production",
    "preview:prod": "npm run build:prod && ts-node --files --project script/tsconfig.json script/patch-dist-runtime-config.ts production && vite preview --host 0.0.0.0",
    "preview:prod:analyze": "ANALYZE=true npm run build:prod && ts-node --files --project script/tsconfig.json script/patch-dist-runtime-config.ts production && (knip --reporter json > dist/knip-report.json || true) && node -e \"const p=require('path');const r=f=>'file://'+p.resolve('dist',f);console.log('\\n>> Bundle report (treemap, used/unused exports, duplicates): '+r('sonda-report.html')+'\\n>> Knip report (unused files/exports/deps, JSON):           '+r('knip-report.json')+'\\n')\" && vite preview --host 0.0.0.0",
    "cache:terminal:clean": "npm cache clean --force && (clear 2>/dev/null || true)",
    "clean:paths": "ts-node --files --project script/tsconfig.json script/clean.ts",
    "clean": "npm run clean:paths -- dist node_modules/.vite node_modules/.cache .eslintcache",
    "clean:all": "node script/clean-all.mts",
    "reset": "npm run clean:all && npm install && npm run api:orval",
    "check:all": "ts-node --files --project script/tsconfig.json script/check-all.ts",
    "format": "ts-node --files --project script/tsconfig.json script/format.ts",
    "api:orval": "npm run clean:paths -- jans_config_api_orval && openapi-merge-cli && orval --config ./orval.config.ts && ts-node --files --project script/tsconfig.json script/fix-orval-enums.ts && ts-node --files --project script/tsconfig.json script/gen-orval-barrel.ts && ts-node --files --project script/tsconfig.json script/verify-orval-mutations.ts",
    "prepare": "cd .. && node admin-ui/node_modules/husky/bin.js admin-ui/.husky"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/plugin-syntax-dynamic-import": "^7.0.0",
    "@babel/plugin-transform-class-properties": "^7.0.0",
    "@babel/plugin-transform-modules-commonjs": "^7.0.0",
    "@babel/plugin-transform-runtime": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "@babel/preset-typescript": "^7.0.0",
    "@eslint/js": "^9.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.0.0",
    "babel-jest": "^30.0.0",
    "dotenv": "^17.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-react": "^7.0.0",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "knip": "^6.14.1",
    "markdownlint-cli2": "^0.22.1",
    "openapi-merge-cli": "^1.0.0",
    "orval": "8.9.1",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.0.0",
    "sonda": "^0.11.1",
    "ts-node": "^10.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-wasm": "^3.0.0"
  },
  "overrides": {
    "react-is": "$react"
  },
  "dependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@janssenproject/cedarling_wasm": "0.0.338",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.0",
    "@openid/appauth": "^1.0.0",
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "ace-builds": "^1.0.0",
    "animejs": "^4.0.0",
    "axios": "^1.0.0",
    "bootstrap": "^5.0.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.0.0",
    "formik": "^2.0.0",
    "i18next": "^26.0.0",
    "lodash": "^4.0.0",
    "react": "^18.0.0",
    "react-ace": "^14.0.0",
    "react-dom": "^18.0.0",
    "react-error-boundary": "^6.0.0",
    "react-i18next": "^17.0.0",
    "react-json-view-lite": "^2.0.0",
    "react-redux": "^9.0.0",
    "react-router-dom": "^7.0.0",
    "react-toastify": "^11.0.0",
    "recharts": "^3.0.0",
    "redux-persist": "^6.0.0",
    "tss-react": "^4.0.0",
    "yup": "^1.0.0"
  }
}
