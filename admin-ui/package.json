{
  "name": "gluu-admin-ui",
  "version": "0.0.0",
  "description": "UI to administer the jans-sever features",
  "keywords": [
    "jans-server",
    "janssen",
    "oauth",
    "admin-ui",
    "gluu"
  ],
  "homepage": "/admin",
  "bugs": {
    "url": "https://github.com/GluuFederation/gluu-admin-ui/issues",
    "email": "team@gluu.org"
  },
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "https://opensource.org/licenses/apache2.0.php"
    }
  ],
  "engines": {
    "node": "^24"
  },
  "main": "index.js",
  "scripts": {
    "test": "jest --forceExit",
    "test:all": "jest --forceExit --runInBand --watchman=false",
    "test:watch": "npm test -- --watch",
    "start": "npm run start:dev",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "build:adminuitest": "vite build --mode adminuitest",
    "build:goldencrane": "vite build --mode goldencrane",
    "start:dev": "vite --mode development",
    "preview": "vite preview",
    "lint": "eslint app/ plugins/ --ext .js,.jsx,.ts,.tsx --fix",
    "lint:check": "eslint app/ plugins/ --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "check:all": "ts-node --files --project script/tsconfig.json script/check-all.ts",
    "format": "ts-node --files --project script/tsconfig.json script/format.ts",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss}\"",
    "api:orval": "rimraf jans_config_api_orval && openapi-merge-cli && orval --config ./orval.config.ts && ts-node --files --project script/tsconfig.json script/fix-orval-enums.ts",
    "plugin:showAll": "ts-node --files --project script/tsconfig.json ./build/plugin-cli.ts --showAllPlugins",
    "plugin:add": "ts-node --files --project script/tsconfig.json ./build/plugin-cli.ts --addPlugin",
    "plugin:remove": "ts-node --files --project script/tsconfig.json ./build/plugin-cli.ts --removePlugin",
    "plugin:clean": "ts-node --files --project script/tsconfig.json ./build/plugin-cli.ts --cleanExceptDefault admin,auth-server --resetPluginConfig",
    "analyze": "ANALYZE=true npm run build:prod",
    "analyze:dev": "ANALYZE=true npm run build:dev",
    "prepare": "cd .. && node admin-ui/node_modules/husky/bin.js admin-ui/.husky"
  },
  "author": "gluu inc.",
  "license": "Apache",
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/plugin-syntax-dynamic-import": "^7.0.0",
    "@babel/plugin-transform-class-properties": "^7.0.0",
    "@babel/plugin-transform-modules-commonjs": "^7.0.0",
    "@babel/plugin-transform-react-jsx": "^7.0.0",
    "@babel/plugin-transform-runtime": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "@babel/preset-typescript": "^7.0.0",
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.0.0",
    "@types/node": "^25.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-toggle": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.0.0",
    "babel-jest": "^30.0.0",
    "commander": "^14.0.0",
    "dotenv": "^17.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "glob": "^13.0.0",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "lint-staged": "^16.0.0",
    "mkdirp": "^3.0.0",
    "orval": "^8.0.0",
    "prettier": "^3.0.0",
    "redux-saga-test-plan": "^4.0.0",
    "rimraf": "^6.0.0",
    "sass": "^1.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^6.0.0",
    "typescript-plugin-css-modules": "^5.0.0",
    "vite": "^8.0.0",
    "vite-plugin-wasm": "^3.0.0",
    "yaml-loader": "^0.9.0"
  },
  "dependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@fortawesome/fontawesome-free": "^7.0.0",
    "@janssenproject/cedarling_wasm": "0.0.338",
    "@material-table/core": "6.4.4",
    "@mui/icons-material": "^5.0.0",
    "@mui/material": "^5.0.0",
    "@mui/x-date-pickers": "^7.0.0",
    "@openid/appauth": "^1.0.0",
    "@reduxjs/toolkit": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "ace-builds": "^1.0.0",
    "animejs": "^4.0.0",
    "axios": "^1.0.0",
    "bootstrap": "^5.0.0",
    "dayjs": "^1.0.0",
    "dompurify": "^3.0.0",
    "formik": "^2.0.0",
    "i18next": "^26.0.0",
    "jszip": "^3.0.0",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.0.0",
    "openapi-merge-cli": "^1.0.0",
    "postcss": "^8.0.0",
    "pretty-checkbox": "^3.0.0",
    "prop-types": "^15.0.0",
    "query-string": "^9.0.0",
    "react": "^18.0.0",
    "react-ace": "^14.0.0",
    "react-bootstrap-typeahead": "^6.0.0",
    "react-dom": "^18.0.0",
    "react-dropzone": "^15.0.0",
    "react-error-boundary": "^6.0.0",
    "react-i18next": "^17.0.0",
    "react-idle-timer": "^5.0.0",
    "react-json-view-lite": "^2.0.0",
    "react-redux": "^9.0.0",
    "react-responsive": "^10.0.0",
    "react-router": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "react-spinners": "^0.17.0",
    "react-toastify": "^11.0.0",
    "react-toggle": "^4.0.0",
    "react-tooltip": "^6.0.0",
    "reactstrap": "^9.0.0",
    "recharts": "^3.0.0",
    "redux-persist": "^6.0.0",
    "redux-saga": "^1.0.0",
    "tss-react": "^4.0.0",
    "unzipper": "^0.12.0",
    "yup": "^1.0.0"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --cache --max-warnings=0",
      "prettier --check"
    ],
    "*.json": [
      "prettier --check"
    ]
  }
}
